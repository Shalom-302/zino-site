rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Newsletter — lecture/écriture publique
    match /newsletter_subscribers/{email} {
      allow read, write: if true;
    }

    // Réservations — soumission publique, lecture/modif admin seulement
    match /reservations/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Contenu du site — lecture publique, écriture admin
    match /site_images/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /environment_images/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /environment_content/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coaches_info/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /programme/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Défaut
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
